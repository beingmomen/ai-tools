{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "opencode-antigravity-auth@latest",
        "@tarquinen/opencode-dcp@latest"
    ],
    "mcp": {
        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest"
            ]
        },
        "nuxt-ui": {
            "type": "remote",
            "url": "https://ui.nuxt.com/mcp",
            "enabled": true
        },
        "nuxt": {
            "type": "remote",
            "url": "https://nuxt.com/mcp",
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ],
            "enabled": true
        }
    }
}